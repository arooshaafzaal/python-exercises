# Q3
def freq(s):
    d={}
    for i in s:
        d[i]=d.get(i,0)+1
    return d

# Q4
def odd_indices(lst):
    return [i for i,x in enumerate(lst) if x%2!=0]

# Q5
def rotate(lst,k):
    return lst[-k:]+lst[:-k]

